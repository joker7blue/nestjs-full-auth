# ==============================================
# NestJS Full Authentication System - Environment Variables
# ==============================================

# Application Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ==============================================
# Database Configuration
# ==============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/nest_auth_db

# Database connection pool settings (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10

# ==============================================
# JWT Configuration
# ==============================================
# Generate secure secrets using: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-here-change-this-too

# Token expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie settings
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax

# ==============================================
# OAuth Providers Configuration
# ==============================================

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback